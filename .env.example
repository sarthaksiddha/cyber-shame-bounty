# CyberShield India — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# -----------------------------------------------------------
# MapMyIndia API (optional)
# Get a key at https://apis.mapmyindia.com/
# Leave blank to use the Leaflet fallback map (works offline too)
# -----------------------------------------------------------
VITE_MAPMYINDIA_KEY=

# -----------------------------------------------------------
# App URL — used for OG tags and canonical links
# -----------------------------------------------------------
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------
# Future: Backend API URL (when you add a server/Supabase etc.)
# -----------------------------------------------------------
# VITE_API_URL=http://localhost:3000
